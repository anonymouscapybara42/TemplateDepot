---
// FAQ.astro

const faqs = [
  {
    question: 'How will I receive my template after purchase?',
    answer: 'Once we verify your payment, your templates will be sent directly to the email address you provided in your payment message. You\'ll receive a download link or the files as an attachment, depending on the file size.',
  },
  {
    question: 'How long does payment verification take?',
    answer: 'Payment verification typically takes 1–2 hours during business hours (9 AM – 6 PM, Monday to Saturday). If you submit outside business hours, we\'ll process it the next morning.',
  },
  {
    question: 'Do templates come with source files?',
    answer: 'Yes! Most templates include editable source files such as Canva links, PowerPoint files, Word documents, or Google Docs — depending on the template type. The specific file formats are listed on each template\'s description.',
  },
  {
    question: 'Can I request modifications to a template?',
    answer: 'Minor text and color modifications can be requested for an additional fee. However, most templates are designed to be easily editable using tools like Canva or Microsoft Office.',
  },
  {
    question: 'Do you offer refunds?',
    answer: 'Because our products are digital and delivered instantly, we generally do not offer refunds. However, if you experience a technical issue or received the wrong file, please contact us immediately and we\'ll make it right.',
  },
  {
    question: 'Can I purchase multiple templates at once?',
    answer: 'Absolutely! List all the templates you want in your payment message or on the upload form. We\'ll send all of them together once verified. Bundle discounts may be available — just ask us on Messenger!',
  },
];
---

<section id="faq" class="py-24 lg:py-32 relative overflow-hidden" style="background:#ffffff;">
  <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg, transparent, rgba(0,95,115,0.2), transparent);"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16 reveal">
      <span class="section-label">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.5">
          <circle cx="6" cy="6" r="5"/><path stroke-linecap="round" d="M6 5v4M6 3.5v.5"/>
        </svg>
        FAQ
      </span>
      <h2 class="section-title text-3xl sm:text-4xl lg:text-5xl mt-3 mb-4">
        Got questions?<br />
        <span class="text-gradient">We've got answers.</span>
      </h2>
      <p class="text-lg max-w-xl mx-auto" style="color:#4A5568;">
        Everything you need to know about Template Depot. Can't find your answer? Contact us.
      </p>
    </div>

    <div class="space-y-3 reveal">
      {faqs.map((faq, i) => (
        <div class="accordion-item card-surface rounded-2xl overflow-hidden transition-all duration-300">
          <button
            class="accordion-trigger w-full flex items-center justify-between px-6 py-5 text-left group"
            data-index={i}
            aria-expanded="false"
          >
            <span class="font-display font-semibold text-sm pr-4" style="color:#2F3E46;">{faq.question}</span>
            <div class="accordion-icon flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center transition-all duration-300" style="border:1.5px solid #D0EDF0;">
              <svg class="w-3.5 h-3.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="#005F73" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </button>
          <div class="accordion-content" data-index={i}>
            <div class="px-6 pb-5">
              <div class="w-full h-px mb-4" style="background:#E8F5E9;"></div>
              <p class="text-sm leading-relaxed" style="color:#4A5568;">{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 reveal">
      <p class="mb-4" style="color:#4A5568;">Still have questions?</p>
      <a href="https://m.me/templatedepot" target="_blank" rel="noopener noreferrer" class="btn-messenger inline-flex">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.917 1.455 5.52 3.733 7.232V22l3.405-1.88c.909.253 1.872.39 2.862.39 5.523 0 10-4.144 10-9.267C22 6.145 17.523 2 12 2zm.99 12.476l-2.548-2.717-4.97 2.717 5.467-5.8 2.608 2.717 4.91-2.717-5.467 5.8z"/>
        </svg>
        Ask Us on Messenger
      </a>
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.accordion-trigger');
  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const index = trigger.getAttribute('data-index');
      const content = document.querySelector(`.accordion-content[data-index="${index}"]`);
      const icon = trigger.querySelector('.accordion-icon svg');
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      triggers.forEach((t) => {
        const idx = t.getAttribute('data-index');
        const c = document.querySelector(`.accordion-content[data-index="${idx}"]`) as HTMLElement;
        t.setAttribute('aria-expanded', 'false');
        if (c) c.classList.remove('open');
        t.querySelector('.accordion-icon svg')?.classList.remove('rotate-180');
      });

      if (!isOpen && content) {
        trigger.setAttribute('aria-expanded', 'true');
        (content as HTMLElement).classList.add('open');
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>