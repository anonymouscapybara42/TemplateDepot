---
// FAQ.astro

const faqs = [
  {
    question: 'How will I receive my template after purchase?',
    answer: 'Once we verify your payment, your templates will be sent directly to the email address you provided in your payment message. You\'ll receive a download link or the files directly as an attachment, depending on the file size.',
  },
  {
    question: 'How long does payment verification take?',
    answer: 'Payment verification typically takes 1–2 hours during business hours (9 AM – 6 PM, Monday to Saturday). If you submit outside business hours, we\'ll process it the next morning. We always aim to be as fast as possible!',
  },
  {
    question: 'Do templates come with source files?',
    answer: 'Yes! Most templates include editable source files such as Canva links, PowerPoint files, Word documents, or Google Docs — depending on the template type. The specific file formats are listed on each template\'s description.',
  },
  {
    question: 'Can I request modifications to a template?',
    answer: 'Minor text and color modifications can be requested for an additional fee. However, most of our templates are designed to be easily editable by non-designers using tools like Canva or Microsoft Office, so you can customize them yourself.',
  },
  {
    question: 'Do you offer refunds?',
    answer: 'Because our products are digital and delivered instantly, we generally do not offer refunds. However, if you experience a technical issue with a template or received the wrong file, please contact us immediately and we\'ll make it right.',
  },
  {
    question: 'Can I purchase multiple templates at once?',
    answer: 'Absolutely! You can purchase multiple templates in one payment. Just list all the templates you want in your message when sending the payment screenshot. We\'ll send all of them together once verified. Bundle discounts may also be available — just ask!',
  },
];
---

<section id="faq" class="py-24 lg:py-32 relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-indigo-500/30 to-transparent"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="section-label">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.5">
          <circle cx="6" cy="6" r="5"/>
          <path stroke-linecap="round" d="M6 5v4M6 3.5v.5"/>
        </svg>
        FAQ
      </span>
      <h2 class="section-title text-3xl sm:text-4xl lg:text-5xl mt-3 mb-4">
        Got questions?<br />
        <span class="text-gradient">We've got answers.</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">
        Everything you need to know about Template Depot. Can't find your answer? Contact us directly.
      </p>
    </div>

    <!-- Accordion -->
    <div class="space-y-3 reveal">
      {faqs.map((faq, i) => (
        <div class="accordion-item glass rounded-2xl border border-white/8 overflow-hidden hover:border-indigo-500/30 transition-all duration-300">
          <button
            class="accordion-trigger w-full flex items-center justify-between px-6 py-5 text-left group"
            data-index={i}
            aria-expanded="false"
          >
            <span class="font-display font-semibold text-white text-sm pr-4 group-hover:text-gradient transition-all">
              {faq.question}
            </span>
            <div class="accordion-icon flex-shrink-0 w-7 h-7 rounded-full border border-white/15 flex items-center justify-center transition-all duration-300 group-hover:border-indigo-500/50 group-hover:bg-indigo-500/10">
              <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </button>
          <div class="accordion-content" data-index={i}>
            <div class="px-6 pb-5">
              <div class="w-full h-px bg-white/5 mb-4"></div>
              <p class="text-slate-400 text-sm leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12 reveal">
      <p class="text-slate-400 mb-4">Still have questions?</p>
      <a href="#contact" class="btn-secondary inline-flex">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        Contact Us
      </a>
    </div>

  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.accordion-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const index = trigger.getAttribute('data-index');
      const content = document.querySelector(`.accordion-content[data-index="${index}"]`);
      const icon = trigger.querySelector('.accordion-icon svg');
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all
      triggers.forEach((t) => {
        const idx = t.getAttribute('data-index');
        const c = document.querySelector(`.accordion-content[data-index="${idx}"]`) as HTMLElement;
        const ic = t.querySelector('.accordion-icon svg');
        t.setAttribute('aria-expanded', 'false');
        if (c) c.classList.remove('open');
        ic?.classList.remove('rotate-180');
      });

      // Open current if it was closed
      if (!isOpen && content) {
        trigger.setAttribute('aria-expanded', 'true');
        (content as HTMLElement).classList.add('open');
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>
