---
// FAQ.astro
const faqs = [
  {
    q: 'How will I receive my template after purchase?',
    a: 'Once we verify your payment, your templates will be sent directly to the email address you provided. You\'ll receive a download link or the files as an attachment depending on file size.',
  },
  {
    q: 'How long does payment verification take?',
    a: 'Verification typically takes 1–2 hours during business hours (9 AM – 6 PM, Mon–Sat). If you submit outside these hours, we\'ll process it the following morning.',
  },
  {
    q: 'Do templates come with source files?',
    a: 'Yes! Most templates include editable source files — Canva links, PowerPoint, Word documents, or Google Docs — depending on the template type. Formats are listed in each template\'s description.',
  },
  {
    q: 'Can I request modifications to a template?',
    a: 'Minor text and color modifications are available for an additional fee. Most templates are designed to be easily editable using Canva or Microsoft Office without extra help.',
  },
  {
    q: 'Do you offer refunds?',
    a: 'Because our products are digital and delivered instantly, we generally do not offer refunds. However, if you received the wrong file or experience a technical issue, contact us and we\'ll fix it immediately.',
  },
  {
    q: 'Can I purchase multiple templates at once?',
    a: 'Absolutely! List all the templates you want in your payment message or on the upload form. We\'ll bundle them and send everything once payment is verified. Ask us on Messenger about bundle discounts!',
  },
];
---

<section id="faq" class="py-20 lg:py-28" style="background:#ffffff;">
  <div class="divider absolute inset-x-0 top-0" aria-hidden="true"></div>

  <div class="container-xl">
    <div class="max-w-2xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-12 reveal">
        <span class="eyebrow mb-3">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="6" cy="6" r="5"/><path stroke-linecap="round" d="M6 5v4M6 3.5v.5"/>
          </svg>
          FAQ
        </span>
        <h2 class="section-heading text-3xl sm:text-4xl lg:text-5xl mt-2 mb-3">
          Got questions?<br />
          <span class="text-teal-gradient">We've got answers.</span>
        </h2>
        <p class="text-lg" style="color:var(--text-secondary);">
          Can't find what you need? Message us directly.
        </p>
      </div>

      <!-- Accordion -->
      <div class="space-y-3 reveal" role="list">
        {faqs.map((faq, i) => (
          <div
            class="accordion-item card overflow-hidden"
            role="listitem"
          >
            <button
              class="accordion-trigger w-full flex items-center justify-between gap-4 px-5 py-4 text-left"
              data-index={i}
              aria-expanded="false"
              aria-controls={`faq-answer-${i}`}
              id={`faq-trigger-${i}`}
            >
              <span
                class="font-display font-semibold text-sm leading-snug"
                style="color:var(--charcoal);"
              >{faq.q}</span>

              <div
                class="accordion-icon shrink-0 w-7 h-7 rounded-full flex items-center justify-center transition-all duration-300"
                style="border:1.5px solid var(--border-mid);"
                aria-hidden="true"
              >
                <svg
                  class="w-3.5 h-3.5 transition-transform duration-300"
                  fill="none" viewBox="0 0 24 24"
                  stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                >
                  <path d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            </button>

            <div
              class="accordion-content"
              id={`faq-answer-${i}`}
              role="region"
              aria-labelledby={`faq-trigger-${i}`}
            >
              <div class="px-5 pb-5">
                <div class="h-px mb-4" style="background:var(--border);"></div>
                <p class="text-sm leading-relaxed" style="color:var(--text-secondary);">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Bottom CTA -->
      <div class="text-center mt-10 reveal">
        <p class="mb-4 text-sm" style="color:var(--text-muted);">Still have questions?</p>
        <a
          href="https://m.me/templatedepot"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-messenger inline-flex"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.917 1.455 5.52 3.733 7.232V22l3.405-1.88c.909.253 1.872.39 2.862.39 5.523 0 10-4.144 10-9.267C22 6.145 17.523 2 12 2zm.99 12.476l-2.548-2.717-4.97 2.717 5.467-5.8 2.608 2.717 4.91-2.717-5.467 5.8z"/>
          </svg>
          Ask Us on Messenger
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>('.accordion-trigger');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const idx     = trigger.dataset.index;
      const content = document.getElementById(`faq-answer-${idx}`)!;
      const icon    = trigger.querySelector<SVGElement>('.accordion-icon svg');
      const isOpen  = trigger.getAttribute('aria-expanded') === 'true';

      // Close all
      triggers.forEach(t => {
        const i = t.dataset.index;
        const c = document.getElementById(`faq-answer-${i}`)!;
        t.setAttribute('aria-expanded', 'false');
        c.classList.remove('open');
        t.querySelector<HTMLElement>('.accordion-icon')!.style.borderColor = 'var(--border-mid)';
        t.querySelector<SVGElement>('.accordion-icon svg')!.style.transform = '';
        t.querySelector<SVGElement>('.accordion-icon svg')!.style.stroke    = 'currentColor';
      });

      // Open if was closed
      if (!isOpen) {
        trigger.setAttribute('aria-expanded', 'true');
        content.classList.add('open');
        const iconWrap = trigger.querySelector<HTMLElement>('.accordion-icon')!;
        iconWrap.style.borderColor = 'var(--teal-mid)';
        iconWrap.style.background  = 'rgba(10,147,150,0.08)';
        if (icon) {
          icon.style.transform = 'rotate(180deg)';
          icon.style.stroke    = 'var(--teal-primary)';
        }
      } else {
        const iconWrap = trigger.querySelector<HTMLElement>('.accordion-icon')!;
        iconWrap.style.background = '';
      }
    });
  });
</script>
