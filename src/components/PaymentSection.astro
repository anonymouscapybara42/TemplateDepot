---
// PaymentSection.astro
---

<section id="payment" class="py-20 lg:py-28" style="background:#ffffff;">
  <div class="divider absolute inset-x-0" style="top:0;"></div>

  <div class="container-xl">

    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <span class="eyebrow mb-3">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="6" cy="6" r="5"/><path stroke-linecap="round" d="M6 3.5v2.5l2 1.5"/>
        </svg>
        Payment
      </span>
      <h2 class="section-heading text-3xl sm:text-4xl lg:text-5xl mt-2 mb-3">
        Easy & secure<br class="hidden sm:block" />
        <span class="text-teal-gradient">payment options</span>
      </h2>
      <p class="text-lg max-w-xl mx-auto" style="color:var(--text-secondary);">
        Scan the QR, pay the exact amount, then send us your screenshot.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-5 items-start">

      <!-- GCash card -->
      <div class="reveal reveal-delay-1 card overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4" style="border-bottom:1px solid var(--border);">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background:rgba(0,119,212,0.10); border:1px solid rgba(0,119,212,0.18);">
              <span class="text-lg" aria-hidden="true">💙</span>
            </div>
            <div>
              <p class="font-display font-semibold text-sm" style="color:var(--charcoal);">GCash</p>
              <p class="text-xs" style="color:var(--text-muted);">Recommended</p>
            </div>
          </div>
          <span class="badge" style="background:rgba(0,119,212,0.08); color:#0077D4; border:1px solid rgba(0,119,212,0.18);">Available</span>
        </div>
        <div class="p-5">
          <!-- QR placeholder — swap in <img> tag when you have the real QR -->
          <div
            class="aspect-square rounded-xl flex flex-col items-center justify-center gap-3 mb-4"
            style="background:var(--bg); border:2px dashed var(--border-mid);"
            aria-label="GCash QR Code placeholder"
          >
            <div class="w-14 h-14 rounded-xl flex items-center justify-center" style="background:var(--mint);">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" style="color:var(--teal-primary);">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z"/>
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM13.5 19.5h.75v.75h-.75v-.75zM19.5 13.5h.75v.75h-.75v-.75zM19.5 19.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75z"/>
              </svg>
            </div>
            <p class="text-sm font-display font-semibold text-center" style="color:var(--charcoal);">GCash QR Code</p>
            <p class="text-xs text-center" style="color:var(--text-faint);">Replace with your QR image</p>
          </div>

          <div class="space-y-2">
            {[
              { label: 'Account Name', val: 'Your Name Here' },
              { label: 'GCash Number', val: '09XX XXX XXXX' },
            ].map(row => (
              <div class="flex items-center justify-between px-3 py-2.5 rounded-lg" style="background:var(--bg); border:1px solid var(--border);">
                <span class="text-xs" style="color:var(--text-faint);">{row.label}</span>
                <span class="text-xs font-display font-semibold" style="color:var(--charcoal);">{row.val}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Maya card -->
      <div class="reveal reveal-delay-2 card overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4" style="border-bottom:1px solid var(--border);">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background:rgba(0,153,77,0.10); border:1px solid rgba(0,153,77,0.18);">
              <span class="text-lg" aria-hidden="true">💚</span>
            </div>
            <div>
              <p class="font-display font-semibold text-sm" style="color:var(--charcoal);">Maya</p>
              <p class="text-xs" style="color:var(--text-muted);">Also accepted</p>
            </div>
          </div>
          <span class="badge" style="background:rgba(0,153,77,0.08); color:#007A33; border:1px solid rgba(0,153,77,0.18);">Available</span>
        </div>
        <div class="p-5">
          <div
            class="aspect-square rounded-xl flex flex-col items-center justify-center gap-3 mb-4"
            style="background:var(--bg); border:2px dashed var(--border-mid);"
            aria-label="Maya QR Code placeholder"
          >
            <div class="w-14 h-14 rounded-xl flex items-center justify-center" style="background:var(--mint);">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" style="color:var(--teal-primary);">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z"/>
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM13.5 19.5h.75v.75h-.75v-.75zM19.5 13.5h.75v.75h-.75v-.75zM19.5 19.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75z"/>
              </svg>
            </div>
            <p class="text-sm font-display font-semibold text-center" style="color:var(--charcoal);">Maya QR Code</p>
            <p class="text-xs text-center" style="color:var(--text-faint);">Replace with your QR image</p>
          </div>

          <div class="space-y-2">
            {[
              { label: 'Account Name', val: 'Your Name Here' },
              { label: 'Maya Number', val: '09XX XXX XXXX' },
            ].map(row => (
              <div class="flex items-center justify-between px-3 py-2.5 rounded-lg" style="background:var(--bg); border:1px solid var(--border);">
                <span class="text-xs" style="color:var(--text-faint);">{row.label}</span>
                <span class="text-xs font-display font-semibold" style="color:var(--charcoal);">{row.val}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Instructions + action buttons -->
      <div class="reveal reveal-delay-3 space-y-4">
        <div class="card overflow-hidden">
          <div class="px-5 py-4" style="border-bottom:1px solid var(--border);">
            <p class="font-display font-semibold text-sm" style="color:var(--charcoal);">Payment Instructions</p>
            <p class="text-xs mt-0.5" style="color:var(--text-muted);">Follow these steps in order</p>
          </div>
          <ol class="p-5 space-y-4" aria-label="Payment steps">
            {[
              'Complete payment via GCash or Maya using the details above.',
              'Take a clear screenshot of your payment confirmation.',
              'Use the Upload Form or Messenger to send your screenshot and your name.',
              'We\'ll verify your payment within 1–2 hours (business hours).',
              'Your templates will be sent to your email after verification.',
            ].map((step, i) => (
              <li class="flex items-start gap-3">
                <div
                  class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5"
                  style="background:rgba(0,95,115,0.09); border:1px solid rgba(0,95,115,0.18);"
                  aria-hidden="true"
                >
                  <span class="font-display font-bold" style="font-size:0.6rem; color:var(--teal-primary);">{i + 1}</span>
                </div>
                <p class="text-sm leading-relaxed" style="color:var(--text-secondary);">{step}</p>
              </li>
            ))}
          </ol>

          <!-- Warning note -->
          <div class="mx-5 mb-5 p-3.5 rounded-xl" style="background:rgba(238,155,0,0.07); border:1px solid rgba(238,155,0,0.22);">
            <div class="flex items-start gap-2">
              <span aria-hidden="true">⚠️</span>
              <div>
                <p class="text-xs font-display font-semibold mb-0.5" style="color:#9A6800;">Important</p>
                <p class="text-xs" style="color:var(--text-secondary);">Send the exact amount matching the template price to avoid delays.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Action buttons -->
        <a href="/submit-payment" class="btn btn-cta w-full justify-center btn-lg">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
          Upload Payment Screenshot
        </a>
        <a href="https://m.me/templatedepot" target="_blank" rel="noopener noreferrer" class="btn btn-messenger w-full justify-center btn-lg">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.917 1.455 5.52 3.733 7.232V22l3.405-1.88c.909.253 1.872.39 2.862.39 5.523 0 10-4.144 10-9.267C22 6.145 17.523 2 12 2zm.99 12.476l-2.548-2.717-4.97 2.717 5.467-5.8 2.608 2.717 4.91-2.717-5.467 5.8z"/>
          </svg>
          Send via Messenger
        </a>
      </div>

    </div>
  </div>
</section>
