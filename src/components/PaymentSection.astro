---
// PaymentSection.astro
---

<section id="payment" class="py-24 lg:py-32 relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-navy-800/30 to-transparent pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="section-label">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.5">
          <circle cx="6" cy="6" r="5"/>
          <path stroke-linecap="round" d="M6 3.5v2.5l2 1.5"/>
        </svg>
        Payment
      </span>
      <h2 class="section-title text-3xl sm:text-4xl lg:text-5xl mt-3 mb-4">
        Easy & secure<br />
        <span class="text-gradient">payment options</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        We accept GCash and Maya payments. Just scan the QR code, complete the transaction, and send us your screenshot.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-6 items-start">

      <!-- GCash QR -->
      <div class="reveal reveal-delay-1">
        <div class="glass rounded-2xl border border-white/8 overflow-hidden card-hover group">
          <!-- Header -->
          <div class="px-5 py-4 border-b border-white/8 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center">
                <span class="text-lg">💙</span>
              </div>
              <div>
                <p class="font-display font-semibold text-white text-sm">GCash</p>
                <p class="text-xs text-slate-500">Recommended</p>
              </div>
            </div>
            <span class="text-xs font-display font-semibold px-2 py-1 rounded-lg bg-blue-500/15 text-blue-400 border border-blue-500/20">Available</span>
          </div>

          <!-- QR Placeholder -->
          <div class="p-5">
            <div class="aspect-square rounded-xl bg-white/5 border-2 border-dashed border-white/15 flex flex-col items-center justify-center gap-3 mb-4 group-hover:border-blue-500/30 transition-colors">
              <div class="w-16 h-16 rounded-lg bg-white/8 flex items-center justify-center">
                <svg class="w-8 h-8 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM13.5 19.5h.75v.75h-.75v-.75zM19.5 13.5h.75v.75h-.75v-.75zM19.5 19.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75z"/>
                </svg>
              </div>
              <div class="text-center">
                <p class="text-sm font-display font-semibold text-white">GCash QR Code</p>
                <p class="text-xs text-slate-500 mt-0.5">Update before going live</p>
              </div>
            </div>

            <div class="space-y-2.5">
              <div class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-white/3 border border-white/5">
                <span class="text-xs text-slate-500">Account Name</span>
                <span class="text-xs font-display font-semibold text-white">Your Name Here</span>
              </div>
              <div class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-white/3 border border-white/5">
                <span class="text-xs text-slate-500">GCash Number</span>
                <span class="text-xs font-display font-semibold text-white">09XX XXX XXXX</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Maya QR -->
      <div class="reveal reveal-delay-2">
        <div class="glass rounded-2xl border border-white/8 overflow-hidden card-hover group">
          <!-- Header -->
          <div class="px-5 py-4 border-b border-white/8 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl bg-green-600/20 border border-green-500/30 flex items-center justify-center">
                <span class="text-lg">💚</span>
              </div>
              <div>
                <p class="font-display font-semibold text-white text-sm">Maya</p>
                <p class="text-xs text-slate-500">Also accepted</p>
              </div>
            </div>
            <span class="text-xs font-display font-semibold px-2 py-1 rounded-lg bg-green-500/15 text-green-400 border border-green-500/20">Available</span>
          </div>

          <!-- QR Placeholder -->
          <div class="p-5">
            <div class="aspect-square rounded-xl bg-white/5 border-2 border-dashed border-white/15 flex flex-col items-center justify-center gap-3 mb-4 group-hover:border-green-500/30 transition-colors">
              <div class="w-16 h-16 rounded-lg bg-white/8 flex items-center justify-center">
                <svg class="w-8 h-8 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM13.5 19.5h.75v.75h-.75v-.75zM19.5 13.5h.75v.75h-.75v-.75zM19.5 19.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75z"/>
                </svg>
              </div>
              <div class="text-center">
                <p class="text-sm font-display font-semibold text-white">Maya QR Code</p>
                <p class="text-xs text-slate-500 mt-0.5">Update before going live</p>
              </div>
            </div>

            <div class="space-y-2.5">
              <div class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-white/3 border border-white/5">
                <span class="text-xs text-slate-500">Account Name</span>
                <span class="text-xs font-display font-semibold text-white">Your Name Here</span>
              </div>
              <div class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-white/3 border border-white/5">
                <span class="text-xs text-slate-500">Maya Number</span>
                <span class="text-xs font-display font-semibold text-white">09XX XXX XXXX</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Instructions -->
      <div class="reveal reveal-delay-3">
        <div class="glass rounded-2xl border border-indigo-500/20 overflow-hidden h-full">
          <div class="px-5 py-4 border-b border-white/8">
            <p class="font-display font-semibold text-white text-sm">Payment Instructions</p>
            <p class="text-xs text-slate-500 mt-0.5">Follow these steps carefully</p>
          </div>
          <div class="p-5 space-y-4">
            {[
              { num: 1, text: 'Complete payment via GCash or Maya to the details above.' },
              { num: 2, text: 'Take a clear screenshot of your payment confirmation screen.' },
              { num: 3, text: 'Send the screenshot to our email or Facebook Messenger with your chosen template name.' },
              { num: 4, text: 'Wait for our team to verify your payment. This usually takes 1–2 hours during business hours.' },
              { num: 5, text: 'Once verified, we\'ll send your templates directly to your email address.' },
            ].map(inst => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-xs font-display font-bold text-indigo-400">{inst.num}</span>
                </div>
                <p class="text-sm text-slate-300 leading-relaxed">{inst.text}</p>
              </div>
            ))}
          </div>

          <!-- Important note -->
          <div class="mx-5 mb-5 p-4 rounded-xl bg-amber-500/10 border border-amber-500/20">
            <div class="flex items-start gap-2.5">
              <span class="text-amber-400 mt-0.5">⚠️</span>
              <div>
                <p class="text-xs font-display font-semibold text-amber-300 mb-1">Important</p>
                <p class="text-xs text-slate-400">Always include the exact amount matching the template price. Incorrect amounts may cause delays.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>
</section>
