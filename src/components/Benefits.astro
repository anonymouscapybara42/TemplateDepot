---
// Benefits.astro

const benefits = [
  {
    icon: '⚡',
    title: 'Instant Delivery',
    description: 'Once your payment is verified, templates are delivered straight to your inbox — no waiting days.',
    stat: '< 2 hours',
  },
  {
    icon: '🎨',
    title: 'Professional Designs',
    description: 'Every template is crafted by experienced designers with real-world business use cases in mind.',
    stat: 'Designer-quality',
  },
  {
    icon: '💼',
    title: 'Business Ready',
    description: 'Formatted for immediate professional use — minimal editing needed before sending to clients.',
    stat: 'Send-ready',
  },
  {
    icon: '📱',
    title: 'Multi-Format',
    description: 'Templates come in Canva, PowerPoint, Word, and Google Docs formats depending on your needs.',
    stat: 'All formats',
  },
];
---

<section id="benefits" class="py-20 lg:py-28 relative overflow-hidden" style="background: #ffffff;">
  <div class="divider absolute top-0 inset-x-0"></div>

  <div class="container-xl">
    <div class="grid lg:grid-cols-2 gap-12 xl:gap-20 items-center">

      <!-- Left: copy + stats -->
      <div class="reveal">
        <span class="eyebrow mb-3">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 1l1.5 3h3L8 6l1 3.5L6 8l-3 1.5L4 6 1.5 4h3L6 1z"/>
          </svg>
          Why Choose Us
        </span>
        <h2 class="section-heading text-3xl sm:text-4xl lg:text-5xl mt-2 mb-5">
          Everything you need,<br />
          <span class="text-teal-gradient">nothing you don't</span>
        </h2>
        <p class="text-lg leading-relaxed mb-8" style="color:var(--text-secondary); max-width:38ch;">
          We give you exactly what professionals need — clean, ready-to-use templates that actually save you time.
        </p>

        <!-- Stat pills -->
        <div class="grid grid-cols-3 gap-4 mb-8">
          {[
            { label: 'Templates Sold', target: 500, suffix: '+' },
            { label: 'Avg. Rating', target: 4.9, decimals: 1, suffix: '★' },
            { label: 'Delivery Time', target: 2, prefix: '< ', suffix: 'h' },
          ].map(stat => (
            <div class="text-center">
              <p class="font-display font-bold text-2xl" style="color:var(--teal-primary);">
                <span
                  class="tabular-nums"
                  data-counter
                  data-counter-target={stat.target}
                  data-counter-prefix={stat.prefix ?? ''}
                  data-counter-suffix={stat.suffix ?? ''}
                  data-counter-decimals={stat.decimals ?? 0}
                >0</span>
              </p>
              <p class="text-xs mt-0.5" style="color:var(--text-muted);">{stat.label}</p>
            </div>
          ))}
        </div>

        <a
          href="https://m.me/templatedepot"
          target="_blank" rel="noopener noreferrer"
          class="btn btn-messenger inline-flex"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.917 1.455 5.52 3.733 7.232V22l3.405-1.88c.909.253 1.872.39 2.862.39 5.523 0 10-4.144 10-9.267C22 6.145 17.523 2 12 2zm.99 12.476l-2.548-2.717-4.97 2.717 5.467-5.8 2.608 2.717 4.91-2.717-5.467 5.8z"/>
          </svg>
          Ask Us on Messenger
        </a>
      </div>

      <!-- Right: benefit cards -->
      <div class="grid sm:grid-cols-2 gap-4">
        {benefits.map((b, i) => ( 
          <div class={`reveal reveal-delay-${i + 1} card p-5 group`}>
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center text-xl mb-4 transition-transform duration-300 group-hover:scale-110"
              style="background:rgba(0,95,115,0.08); border:1px solid rgba(0,95,115,0.14);"
              aria-hidden="true"
            >
              {b.icon}
            </div>
            <h3 class="font-display font-semibold mb-1.5" style="font-size:var(--text-base); color:var(--charcoal);">{b.title}</h3>
            <p class="text-sm leading-relaxed mb-3" style="color:var(--text-secondary);">{b.description}</p>
            <div class="inline-flex items-center gap-1.5">
              <div class="w-1 h-1 rounded-full" style="background:var(--teal-mid);" aria-hidden="true"></div>
              <span class="font-display font-semibold" style="font-size:var(--text-xs); color:var(--teal-mid);">{b.stat}</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>

  <div class="divider absolute bottom-0 inset-x-0"></div>
</section>

<script>
  const animateCounter = (element: HTMLElement) => {
    const target = Number(element.dataset.counterTarget || '0');
    const prefix = element.dataset.counterPrefix || '';
    const suffix = element.dataset.counterSuffix || '';
    const decimals = Number(element.dataset.counterDecimals || '0');
    const duration = 1600;
    const startTime = performance.now();

    const formatValue = (value: number) => {
      const formattedValue = value.toFixed(decimals);
      return `${prefix}${formattedValue}${suffix}`;
    };

    const updateValue = (currentTime: number) => {
      const progress = Math.min((currentTime - startTime) / duration, 1);
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      const currentValue = target * easedProgress;

      element.textContent = formatValue(currentValue);

      if (progress < 1) {
        requestAnimationFrame(updateValue);
      } else {
        element.textContent = formatValue(target);
      }
    };

    element.textContent = formatValue(0);
    requestAnimationFrame(updateValue);
  };

  const counters = document.querySelectorAll<HTMLElement>('[data-counter]');

  if (counters.length) {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => counters.forEach(animateCounter), { once: true });
    } else {
      counters.forEach(animateCounter);
    }
  }
</script>
