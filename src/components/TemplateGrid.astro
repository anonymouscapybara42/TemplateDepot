    price: '₱299',
    tag: 'Best Seller',
    tagBg: 'rgba(0,95,115,0.10)',
    tagColor: '#005F73',
    gradientFrom: 'rgba(0,95,115,0.12)',
    gradientTo: 'rgba(10,147,150,0.08)',
