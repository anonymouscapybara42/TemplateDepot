---

<section id="templates" class="py-24 lg:py-32 relative overflow-hidden" style="background:#F9FAFB;">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] rounded-full blur-3xl pointer-events-none" style="background:rgba(0,95,115,0.04);"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-12 lg:mb-14 reveal">
      <span class="eyebrow mb-3">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 12 12" aria-hidden="true">
          <rect width="5" height="5" rx="1"/><rect x="7" width="5" height="5" rx="1"/>
          <rect y="7" width="5" height="5" rx="1"/><rect x="7" y="7" width="5" height="5" rx="1"/>
        </svg>
        Our Templates
      </span>
      <h2 class="section-heading text-3xl sm:text-4xl lg:text-5xl mt-2 mb-3">
        Ready-Made Templates<br class="hidden sm:block" />
        <span class="text-teal-gradient">Built for Professionals</span>
      </h2>

   <div class="relative max-w-xl mx-auto mt-6 mb-8">
  <svg
    class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 pointer-events-none"
    fill="none"
    viewBox="0 0 24 24"
    stroke="#005F73"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.1-5.4a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z" />
  </svg>

  <input
    id="template-search"
    type="search"
    placeholder="Search templates..."
    class="w-full rounded-2xl pl-12 pr-4 py-4 text-sm font-display outline-none transition-all"
    style="background:#ffffff; color:#2F3E46; border:1.5px solid #D0EDF0; box-shadow:0 14px 35px rgba(0,95,115,0.08);"
  />
</div>

    <!-- Category filter pills -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-12 reveal reveal-delay-1">
      {['All', 'Business', 'Marketing', 'Resume', 'Social Media', 'Website', 'Presentation', 'Productivity'].map((cat, i) => (
        <button
          class="filter-btn px-4 py-2 rounded-full text-sm font-display font-medium transition-all duration-200"
          style={i === 0
            ? 'background:#005F73; color:#ffffff; border:1.5px solid #005F73;'
            : 'background:transparent; color:#4A5568; border:1.5px solid #D0EDF0;'}
          data-filter={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Template grid -->
    <div id="template-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {templates.map((t, i) => (
        <div
          class={`template-card reveal reveal-delay-${Math.min(i % 4 + 1, 4)} relative card-surface rounded-2xl overflow-hidden card-hover group cursor-pointer ticket-stub`}
          data-category={t.category}
          data-search={`${t.title} ${t.description} ${t.category}`.toLowerCase()}


        >
          <!-- Preview area -->
          <div class="relative h-44 flex items-center justify-center overflow-hidden" style={`background:linear-gradient(135deg, ${t.gradientFrom}, ${t.gradientTo});`}>
            <div class="absolute inset-0 opacity-15" style="background-image: linear-gradient(rgba(0,95,115,0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(0,95,115,0.15) 1px, transparent 1px); background-size: 20px 20px;"></div>
            <div class="relative text-5xl select-none filter drop-shadow-md group-hover:scale-110 transition-transform duration-300">
              {t.icon}
            </div>
            <!-- Category badge -->
            <div class="absolute top-3 left-3">
              <span class="text-xs font-display font-medium px-2 py-0.5 rounded-full" style="background:rgba(255,255,255,0.85); color:#005F73; backdrop-filter:blur(4px);">
                {t.category}
              </span>
            </div>
            {t.tag && (
              <div class="absolute top-3 right-3">
                <span class="text-xs font-display font-semibold px-2 py-0.5 rounded-full" style={`background:${t.tagBg}; color:${t.tagColor};`}>
                  {t.tag}
                </span>
              </div>
            )}
          </div>

          <!-- Card body -->
          <div class="p-4" style="background:#ffffff;">
            <h3 class="font-display font-semibold text-sm mb-1.5" style="color:#2F3E46;">{t.title}</h3>
            <p class="text-xs leading-relaxed mb-4" style="color:#718096;">{t.description}</p>
          </div>

          <!-- Ticket stub bottom -->
          <div class="px-4 pb-4 pt-3" style="background:#ffffff; border-top:1px dashed rgba(0,95,115,0.2);">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs font-display" style="color:#94A3B8;">Starting at</p>
                <p class="text-lg font-display font-bold" style="color:#0A9396;">{t.price}</p>
              </div>
              <!-- AMBER CTA — conversion action -->
              <a
                href="/submit-payment"
                class="btn-cta text-xs px-3.5 py-2 rounded-lg"
                style="font-size:0.75rem; padding:0.5rem 0.875rem; border-radius:0.5rem;"
              >
                Buy Now →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12 reveal">
      <p class="mb-4" style="color:var(--text-secondary);">
        Don't see what you need? We create custom templates too.
      </p>
      <a href="https://m.me/templatedepot" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-lg inline-flex">
        Request a Custom Template
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const templateCards = document.querySelectorAll('.template-card');
  const templateSearch = document.getElementById('template-search') as HTMLInputElement;

  let activeFilter = 'All';

  const updateTemplates = () => {
    const searchValue = templateSearch?.value.toLowerCase().trim() || '';

    templateCards.forEach((card) => {
      const cat = card.getAttribute('data-category');
      const searchText = card.getAttribute('data-search') || '';
      const el = card as HTMLElement;

      const matchesCategory = activeFilter === 'All' || cat === activeFilter;
      const matchesSearch = searchText.includes(searchValue);

      el.style.display = matchesCategory && matchesSearch ? '' : 'none';
    });
  };

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeFilter = btn.getAttribute('data-filter') || 'All';

      filterBtns.forEach((b) => {
        const el = b as HTMLElement;
        el.style.background = 'transparent';
        el.style.color = '#4A5568';
        el.style.border = '1.5px solid #D0EDF0';
      });

      const active = btn as HTMLElement;
      active.style.background = '#005F73';
      active.style.color = '#ffffff';
      active.style.border = '1.5px solid #005F73';

      updateTemplates();
    });
  });

  templateSearch?.addEventListener('input', updateTemplates);
</script>