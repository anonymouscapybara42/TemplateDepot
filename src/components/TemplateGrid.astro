    price: '₱499',
    tag: 'New',
    tagBg: 'rgba(10,147,150,0.12)',
    tagColor: '#0A9396',
    gradientFrom: 'rgba(10,147,150,0.12)',
    gradientTo: 'rgba(232,245,233,0.80)',
    icon: '🌐',
    includes: ['HTML/CSS source files', 'Responsive on all devices', 'Projects grid', 'Contact form (static)', 'Deployment guide'],
    formats: ['HTML/CSS', 'ZIP file'],
    images: ['🌐', '💻', '🎨', '📐'],
  },
  {
    id: 8,
    title: 'Small Business Starter Pack',
    description: 'Everything a small business needs: logo guide, invoices, receipts, and social templates.',
    longDescription: `The complete starter kit for Filipino entrepreneurs launching or rebranding a small business. Everything designed to work together as a cohesive brand system.\n\nIncludes: brand color & font guide, 3 invoice templates, 2 official receipt formats, business card layout, email signature template, and a 10-post social media kit. Editable in Canva, Word, and Google Docs.`,
    category: 'Business',
    price: '₱599',
    tag: 'Bundle',
    tagBg: 'rgba(238,155,0,0.15)',
    tagColor: '#B87200',
    gradientFrom: 'rgba(232,245,233,0.90)',
    gradientTo: 'rgba(0,95,115,0.08)',
    icon: '🚀',
    includes: ['Brand guide (colors & fonts)', '3 invoice templates', '2 official receipt formats', 'Business card layout', 'Email signature + social kit'],
    formats: ['Canva', 'DOCX', 'Google Docs'],
    images: ['🚀', '🎨', '📄', '💳'],
  },
];
---

<!-- ─────────────────────────────────────────────────────────────
     SECTION — template grid
───────────────────────────────────────────────────────────── -->
<section id="templates" class="py-20 lg:py-28 relative overflow-hidden" style="background:var(--bg);">
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] rounded-full blur-3xl pointer-events-none"
    style="background:rgba(0,95,115,0.04);"
    aria-hidden="true"
  ></div>

  <div class="container-xl relative">

    <!-- Section header -->
    <div class="text-center mb-10 reveal">
      <span class="eyebrow mb-3">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 12 12" aria-hidden="true">
          <rect width="5" height="5" rx="1"/><rect x="7" width="5" height="5" rx="1"/>
          <rect y="7" width="5" height="5" rx="1"/><rect x="7" y="7" width="5" height="5" rx="1"/>
        </svg>
        Our Templates
      </span>
      <h2 class="section-heading text-3xl sm:text-4xl lg:text-5xl mt-2 mb-3">
        Ready-Made Templates<br class="hidden sm:block" />
        <span class="text-teal-gradient">Built for Professionals</span>
      </h2>
      <p class="text-lg max-w-2xl mx-auto" style="color:var(--text-secondary);">
        Crafted by designers who understand what Filipino professionals actually need.
      </p>
    </div>

    <!-- Search bar -->
    <div class="relative max-w-xl mx-auto mb-8 reveal">
      <svg
        class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 pointer-events-none"
        fill="none" viewBox="0 0 24 24" stroke-width="2"
        style="color:var(--teal-primary);"
        aria-hidden="true"
      >
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.1-5.4a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z"/>
      </svg>
      <input
        id="template-search"
        type="search"
        placeholder="Search templates…"
        class="input w-full pl-11 pr-4"
        style="border-radius:9999px; padding-top:0.75rem; padding-bottom:0.75rem; box-shadow:0 4px 20px rgba(0,95,115,0.08);"
        aria-label="Search templates"
      />
    </div>

    <!-- Category filters -->
    <div
      class="flex flex-wrap items-center justify-center gap-2 mb-10 reveal reveal-delay-1"
      role="group"
      aria-label="Filter templates by category"
    >
      {['All', 'Business', 'Marketing', 'Resume', 'Social Media', 'Website', 'Presentation', 'Productivity'].map((cat, i) => (
        <button
          class="filter-btn font-display font-medium rounded-full px-4 py-1.5 text-sm transition-all duration-200 border"
          style={i === 0
            ? 'background:var(--teal-primary); color:#fff; border-color:var(--teal-primary);'
            : 'background:transparent; color:var(--text-secondary); border-color:var(--border-mid);'}
          data-filter={cat}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- No-results message (hidden by default) -->
    <div
      id="no-results"
      class="hidden text-center py-16"
      role="status"
      aria-live="polite"
    >
      <p class="text-4xl mb-3" aria-hidden="true">🔍</p>
      <p class="font-display font-semibold" style="color:var(--charcoal);">No templates found</p>
      <p class="text-sm mt-1" style="color:var(--text-muted);">Try a different search term or browse all categories.</p>
    </div>

    <!-- Template grid -->
    <div
      id="template-grid"
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-5"
    >
      {templates.map((t, i) => (
        <article
          class={`template-card reveal reveal-delay-${Math.min(i % 4 + 1, 4)} relative card overflow-hidden cursor-pointer group`}
          data-category={t.category}
          data-search={`${t.title} ${t.description} ${t.category}`.toLowerCase()}
          data-id={t.id}
          role="button"
          tabindex="0"
          aria-label={`View details for ${t.title} — ${t.price}`}
        >
          <!-- Preview thumbnail -->
          <div
            class="relative h-44 flex items-center justify-center overflow-hidden"
            style={`background:linear-gradient(135deg, ${t.gradientFrom}, ${t.gradientTo});`}
          >
            <!-- Grid decoration -->
            <div
              class="absolute inset-0"
              style="background-image:linear-gradient(rgba(0,95,115,0.07) 1px,transparent 1px),linear-gradient(90deg,rgba(0,95,115,0.07) 1px,transparent 1px); background-size:24px 24px;"
              aria-hidden="true"
            ></div>

            <!-- Main icon -->
            <span
              class="relative text-5xl select-none transition-transform duration-300 group-hover:scale-110"
              role="img"
              aria-label={t.title}
            >{t.icon}</span>

            <!-- "Click to view" hint — appears on hover -->
            <div
              class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200"
              style="background:rgba(0,95,115,0.55);"
              aria-hidden="true"
            >
              <div class="flex flex-col items-center gap-1.5">
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.75">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
                <span class="text-white font-display font-semibold text-xs tracking-wide">View Details</span>
              </div>
            </div>

            <!-- Category pill -->
            <div class="absolute top-3 left-3">
              <span
                class="text-xs font-display font-medium px-2 py-0.5 rounded-full"
                style="background:rgba(255,255,255,0.88); color:var(--teal-primary); backdrop-filter:blur(4px);"
              >{t.category}</span>
            </div>

            {t.tag && (
              <div class="absolute top-3 right-3">
                <span
                  class="text-xs font-display font-semibold px-2 py-0.5 rounded-full"
                  style={`background:${t.tagBg}; color:${t.tagColor};`}
                >{t.tag}</span>
              </div>
            )}
          </div>

          <!-- Card body -->
          <div class="p-4 pb-3" style="background:var(--surface);">
            <h3 class="font-display font-semibold mb-1.5" style="font-size:var(--text-sm); color:var(--charcoal); line-height:1.35;">{t.title}</h3>
            <p class="text-xs leading-relaxed" style="color:var(--text-muted);">{t.description}</p>
          </div>

          <!-- Ticket-stub footer -->
          <div
            class="px-4 pb-4 pt-3"
            style="background:var(--surface); border-top:1px dashed var(--border-mid);"
          >
            <div class="flex items-center justify-between gap-3">
              <div>
                <p class="font-display" style="font-size:0.65rem; color:var(--text-faint); text-transform:uppercase; letter-spacing:0.06em;">Starting at</p>
                <p class="font-display font-bold mt-0.5" style="font-size:var(--text-lg); color:var(--teal-mid);">{t.price}</p>
              </div>
              <!-- Amber CTA — stops propagation so card click still works -->
              <button
                class="btn btn-cta btn-sm open-modal-btn shrink-0"
                data-id={t.id}
                aria-label={`Buy ${t.title} for ${t.price}`}
              >
                Buy Now
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12 reveal">
      <p class="mb-4" style="color:var(--text-secondary);">
        Don't see what you need? We create custom templates too.
      </p>
      <a
        href={MESSENGER_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary btn-lg inline-flex"
      >
        Request a Custom Template
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────
     MODAL — product detail view
     • Triggered by clicking any template card or "Buy Now"
     • Rendered once, data swapped in via JS
───────────────────────────────────────────────────────────── -->
<div
  id="product-modal"
  class="fixed inset-0 z-[200] flex items-end sm:items-center justify-center p-0 sm:p-4"
  style="display:none;"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div
    id="modal-backdrop"
    class="absolute inset-0"
    style="background:rgba(0,0,0,0.48); backdrop-filter:blur(4px);"
    aria-hidden="true"
  ></div>

  <!-- Panel -->
  <div
    id="modal-panel"
    class="relative w-full sm:max-w-3xl lg:max-w-4xl max-h-[92dvh] sm:max-h-[88dvh] overflow-hidden flex flex-col"
    style="background:var(--surface); border-radius:1.5rem 1.5rem 0 0; sm:border-radius:1.5rem; box-shadow:0 24px 80px rgba(0,0,0,0.22);"
  >

    <!-- ── Close button (always visible, top-right) ── -->
    <button
      id="modal-close"
      class="absolute top-4 right-4 z-10 w-9 h-9 rounded-full flex items-center justify-center transition-all duration-150"
      style="background:rgba(47,62,70,0.08); color:var(--charcoal);"
      aria-label="Close product details"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- ── Scrollable content ── -->
    <div class="overflow-y-auto flex-1 scrollbar-hide">

      <!-- Image gallery area -->
      <div
        id="modal-gallery"
        class="relative w-full overflow-hidden"
        style="background:linear-gradient(135deg, rgba(0,95,115,0.10), rgba(232,245,233,0.80)); min-height:260px; max-height:320px;"
      >
        <!-- Main display -->
        <div id="modal-main-image" class="w-full h-64 sm:h-80 flex items-center justify-center text-8xl select-none" aria-live="polite">
          <!-- populated by JS -->
        </div>

        <!-- Thumbnail strip -->
        <div
          id="modal-thumbs"
          class="absolute bottom-3 left-1/2 -translate-x-1/2 flex items-center gap-2"
          role="tablist"
          aria-label="Product image gallery"
        >
          <!-- populated by JS -->
        </div>

        <!-- Prev / Next arrows -->
        <button
          id="gallery-prev"
          class="absolute left-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full flex items-center justify-center transition-all duration-150"
          style="background:rgba(255,255,255,0.85); color:var(--charcoal); box-shadow:0 2px 8px rgba(0,0,0,0.12);"
          aria-label="Previous image"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button
          id="gallery-next"
          class="absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full flex items-center justify-center transition-all duration-150"
          style="background:rgba(255,255,255,0.85); color:var(--charcoal); box-shadow:0 2px 8px rgba(0,0,0,0.12);"
          aria-label="Next image"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>

      <!-- Product info + actions -->
      <div class="p-5 sm:p-8">
        <div class="flex flex-col lg:flex-row gap-6 lg:gap-10">

          <!-- Left: details -->
          <div class="flex-1 min-w-0">

            <!-- Tag + category -->
            <div class="flex items-center gap-2 mb-3 flex-wrap">
              <span id="modal-category" class="badge badge-teal">—</span>
              <span id="modal-tag" class="badge badge-amber hidden">—</span>
            </div>

            <!-- Title -->
            <h3 id="modal-title" class="font-display font-bold mb-3" style="font-size:clamp(1.25rem,3vw,1.75rem); color:var(--charcoal); letter-spacing:-0.02em; line-height:1.2;">
              Product Title
            </h3>

            <!-- Long description -->
            <div id="modal-desc" class="text-sm leading-relaxed mb-5" style="color:var(--text-secondary); white-space:pre-line;">
              Description text here
            </div>

            <!-- What's included -->
            <div class="mb-5">
              <p class="eyebrow mb-3">What's Included</p>
              <ul id="modal-includes" class="space-y-2">
                <!-- populated by JS -->
              </ul>
            </div>

            <!-- Formats -->
            <div>
              <p class="eyebrow mb-2">File Formats</p>
              <div id="modal-formats" class="flex flex-wrap gap-2">
                <!-- populated by JS -->
              </div>
            </div>
          </div>

          <!-- Right: pricing + CTA block (sticky on desktop) -->
          <aside
            class="lg:w-56 xl:w-64 shrink-0"
            aria-label="Pricing and purchase options"
          >
            <div
              class="rounded-2xl p-5 sticky top-4"
              style="background:var(--bg); border:1px solid var(--border);"
            >
              <!-- Price -->
              <div class="mb-5 pb-4" style="border-bottom:1px solid var(--border);">
                <p class="font-display" style="font-size:0.65rem; color:var(--text-faint); text-transform:uppercase; letter-spacing:0.08em;">Price</p>
                <p id="modal-price" class="font-display font-bold mt-1" style="font-size:2rem; color:var(--teal-mid); letter-spacing:-0.02em;">₱—</p>
                <p class="text-xs mt-0.5" style="color:var(--text-faint);">One-time payment</p>
              </div>

              <!-- CTAs -->
              <div class="space-y-2.5">
                <!-- Amber: primary conversion -->
                <a
                  id="modal-buy-btn"
                  href="/submit-payment"
                  class="btn btn-cta btn-lg w-full justify-center"
                  aria-label="Submit payment to buy this template"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                  </svg>
                  Buy Now
                </a>

                <!-- Messenger -->
                <a
                  id="modal-messenger-btn"
                  href={MESSENGER_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-messenger w-full justify-center"
                  aria-label="Message us on Messenger about this template"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.917 1.455 5.52 3.733 7.232V22l3.405-1.88c.909.253 1.872.39 2.862.39 5.523 0 10-4.144 10-9.267C22 6.145 17.523 2 12 2zm.99 12.476l-2.548-2.717-4.97 2.717 5.467-5.8 2.608 2.717 4.91-2.717-5.467 5.8z"/>
                  </svg>
                  Message on Messenger
                </a>

                <!-- Email — pre-fills subject with product name -->
                <a
                  id="modal-email-btn"
                  href="#"
                  class="btn btn-secondary w-full justify-center"
                  aria-label="Send us an email about this template"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                  Send Email
                </a>
              </div>

              <!-- Trust note -->
              <p class="text-center mt-4" style="font-size:0.7rem; color:var(--text-faint); line-height:1.5;">
                Delivered to your email within 1–2 hours of payment verification.
              </p>
            </div>
          </aside>

        </div>
      </div>
    </div>
  </div>
</div>

<!-- ─────────────────────────────────────────────────────────────
     SCRIPT
───────────────────────────────────────────────────────────── -->
<script define:vars={{ templates, MESSENGER_URL, CONTACT_EMAIL }}>

  /* ── Config (matches frontmatter) ── */
  const MSGR  = MESSENGER_URL;
  const EMAIL = CONTACT_EMAIL;

  /* ── DOM refs ── */
  const modal       = document.getElementById('product-modal');
  const backdrop    = document.getElementById('modal-backdrop');
  const panel       = document.getElementById('modal-panel');
  const closeBtn    = document.getElementById('modal-close');
  const mainImg     = document.getElementById('modal-main-image');
  const thumbsWrap  = document.getElementById('modal-thumbs');
  const prevBtn     = document.getElementById('gallery-prev');
  const nextBtn     = document.getElementById('gallery-next');
  const noResults   = document.getElementById('no-results');

  /* ── Filter / search state ── */
  const filterBtns    = document.querySelectorAll('.filter-btn');
  const templateCards = document.querySelectorAll('.template-card');
  const searchInput   = document.getElementById('template-search');
  let activeFilter = 'All';

  function applyFilters() {
    const q = (searchInput?.value ?? '').toLowerCase().trim();
    let visCount = 0;
    templateCards.forEach(card => {
      const el  = card;
      const cat = el.getAttribute('data-category') ?? '';
      const txt = el.getAttribute('data-search')   ?? '';
      const show = (activeFilter === 'All' || cat === activeFilter) &&
                   (!q || txt.includes(q));
      el.style.display = show ? '' : 'none';
      if (show) visCount++;
    });
    if (noResults) noResults.style.display = visCount === 0 ? 'block' : 'none';
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.getAttribute('data-filter') ?? 'All';
      filterBtns.forEach(b => {
        const el = b;
        el.style.background  = 'transparent';
        el.style.color       = 'var(--text-secondary)';
        el.style.borderColor = 'var(--border-mid)';
        el.setAttribute('aria-pressed', 'false');
      });
      btn.style.background  = 'var(--teal-primary)';
      btn.style.color       = '#fff';
      btn.style.borderColor = 'var(--teal-primary)';
      btn.setAttribute('aria-pressed', 'true');
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', applyFilters);

  /* ── Gallery state ── */
  let galleryImages = [];
  let galleryIndex  = 0;

  function renderGallery(images) {
    galleryImages = images;
    galleryIndex  = 0;
    showGallerySlide(0);
    buildThumbs(images);
  }

  function showGallerySlide(idx) {
    galleryIndex = (idx + galleryImages.length) % galleryImages.length;
    if (mainImg) {
      mainImg.style.opacity = '0';
      mainImg.style.transform = 'scale(0.97)';
      setTimeout(() => {
        mainImg.textContent = galleryImages[galleryIndex];
        mainImg.style.opacity   = '1';
        mainImg.style.transform = 'scale(1)';
      }, 120);
    }
    // Update thumb active states
    document.querySelectorAll('.gallery-thumb').forEach((th, i) => {
      th.style.opacity     = i === galleryIndex ? '1'   : '0.5';
      th.style.transform   = i === galleryIndex ? 'scale(1.15)' : 'scale(1)';
      th.style.borderColor = i === galleryIndex ? 'var(--teal-primary)' : 'transparent';
      th.setAttribute('aria-selected', i === galleryIndex ? 'true' : 'false');
    });
  }

  function buildThumbs(images) {
    if (!thumbsWrap) return;
    thumbsWrap.innerHTML = '';
    images.forEach((img, i) => {
      const btn = document.createElement('button');
      btn.className  = 'gallery-thumb w-10 h-10 rounded-xl flex items-center justify-center text-xl transition-all duration-200 border-2';
      btn.style.cssText = `background:rgba(255,255,255,0.85); border-color:${i === 0 ? 'var(--teal-primary)' : 'transparent'}; opacity:${i === 0 ? '1' : '0.5'};`;
      btn.textContent = img;
      btn.setAttribute('role', 'tab');
      btn.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
      btn.setAttribute('aria-label', `Gallery image ${i + 1}`);
      btn.addEventListener('click', () => showGallerySlide(i));
      thumbsWrap.appendChild(btn);
    });
  }

  prevBtn?.addEventListener('click', () => showGallerySlide(galleryIndex - 1));
  nextBtn?.addEventListener('click', () => showGallerySlide(galleryIndex + 1));

  // Keyboard arrow nav inside modal
  document.addEventListener('keydown', e => {
    if (!modal || modal.style.display === 'none') return;
    if (e.key === 'ArrowLeft')  { e.preventDefault(); showGallerySlide(galleryIndex - 1); }
    if (e.key === 'ArrowRight') { e.preventDefault(); showGallerySlide(galleryIndex + 1); }
    if (e.key === 'Escape')     closeModal();
  });

  /* ── Populate modal with template data ── */
  function populateModal(t) {
    // Gallery
    const galleryEl = document.getElementById('modal-gallery');
    if (galleryEl) {
      galleryEl.style.background = `linear-gradient(135deg, ${t.gradientFrom}, ${t.gradientTo})`;
    }
    renderGallery(t.images);

    // Main image transition styles
    if (mainImg) {
      mainImg.style.transition = 'opacity 0.12s ease, transform 0.12s ease';
    }

    // Category + tag
    const catEl = document.getElementById('modal-category');
    const tagEl = document.getElementById('modal-tag');
    if (catEl) catEl.textContent = t.category;
    if (tagEl) {
      if (t.tag) {
        tagEl.textContent = t.tag;
        tagEl.style.background   = t.tagBg  || 'rgba(238,155,0,0.12)';
        tagEl.style.color        = t.tagColor || '#9A6800';
        tagEl.style.borderColor  = t.tagColor || '#9A6800';
        tagEl.classList.remove('hidden');
      } else {
        tagEl.classList.add('hidden');
      }
    }

    // Title
    const titleEl = document.getElementById('modal-title');
    if (titleEl) titleEl.textContent = t.title;

    // Long description
    const descEl = document.getElementById('modal-desc');
    if (descEl) descEl.textContent = t.longDescription;

    // Includes list
    const incEl = document.getElementById('modal-includes');
    if (incEl) {
      incEl.innerHTML = t.includes.map(item => `
        <li class="flex items-start gap-2.5">
          <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" style="color:var(--teal-mid);" aria-hidden="true">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-sm" style="color:var(--text-secondary);">${item}</span>
        </li>
      `).join('');
    }

    // Formats
    const fmtEl = document.getElementById('modal-formats');
    if (fmtEl) {
      fmtEl.innerHTML = t.formats.map(f => `
        <span class="badge badge-teal">${f}</span>
      `).join('');
    }

    // Price
    const priceEl = document.getElementById('modal-price');
    if (priceEl) priceEl.textContent = t.price;

    // Buy Now button — links to submit-payment with template pre-selected via query param
    const buyBtn = document.getElementById('modal-buy-btn');
    if (buyBtn) {
      buyBtn.href = `/submit-payment?template=${encodeURIComponent(t.title)}&price=${encodeURIComponent(t.price)}`;
      buyBtn.setAttribute('aria-label', `Buy ${t.title} for ${t.price}`);
    }

    // Messenger — links with pre-filled message via t.me deep link param (Messenger doesn't support this, so we just set the URL)
    const msgrBtn = document.getElementById('modal-messenger-btn');
    if (msgrBtn) {
      msgrBtn.href = MSGR;
      msgrBtn.setAttribute('aria-label', `Message on Messenger about ${t.title}`);
    }

    // Email — product-specific mailto
    const emailBtn = document.getElementById('modal-email-btn');
    if (emailBtn) {
      const subject = encodeURIComponent(`[Template Depot] I want to buy: ${t.title} (${t.price})`);
      const body    = encodeURIComponent(
        `Hi Template Depot!\n\nI'm interested in purchasing:\n\n` +
        `Template: ${t.title}\nPrice: ${t.price}\n\n` +
        `Please send me payment details.\n\nThank you!`
      );
      emailBtn.href = `mailto:${EMAIL}?subject=${subject}&body=${body}`;
      emailBtn.setAttribute('aria-label', `Send email about ${t.title}`);
    }
  }

  /* ── Modal open / close ── */
  let previouslyFocused = null;

  function openModal(id) {
    const t = templates.find(x => x.id === id);
    if (!t || !modal) return;

    previouslyFocused = document.activeElement;
    populateModal(t);

    // Show modal
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    // Animate in
    requestAnimationFrame(() => {
      if (panel) {
        panel.style.transition = 'transform 0.32s cubic-bezier(0.4,0,0.2,1), opacity 0.28s ease';
        panel.style.transform  = 'translateY(100%)';
        panel.style.opacity    = '0';
        requestAnimationFrame(() => {
          panel.style.transform = 'translateY(0)';
          panel.style.opacity   = '1';
        });
      }
      if (backdrop) {
        backdrop.style.transition = 'opacity 0.28s ease';
        backdrop.style.opacity    = '0';
        requestAnimationFrame(() => { backdrop.style.opacity = '1'; });
      }
    });

    // Focus close button for accessibility
    setTimeout(() => closeBtn?.focus(), 60);
  }

  function closeModal() {
    if (!modal || !panel) return;

    // Animate out
    panel.style.transform = 'translateY(40px)';
    panel.style.opacity   = '0';
    if (backdrop) backdrop.style.opacity = '0';

    setTimeout(() => {
      modal.style.display  = 'none';
      panel.style.transform = '';
      panel.style.opacity   = '';
      document.body.style.overflow = '';
      previouslyFocused?.focus();
    }, 280);
  }

  // Trigger from card click
  templateCards.forEach(card => {
    const id = parseInt(card.getAttribute('data-id') ?? '0', 10);
    card.addEventListener('click', (e) => {
      // Don't re-open if they clicked the Buy Now button (it has its own handler)
      if ((e.target).closest('.open-modal-btn')) return;
      openModal(id);
    });
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(id); }
    });
  });

  // Trigger from Buy Now buttons
  document.querySelectorAll('.open-modal-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = parseInt(btn.getAttribute('data-id') ?? '0', 10);
      openModal(id);
    });
  });

  // Close via X button
  closeBtn?.addEventListener('click', closeModal);

  // Close via backdrop click
  backdrop?.addEventListener('click', closeModal);

  /* ── Focus trap inside modal ── */
  modal?.addEventListener('keydown', e => {
    if (e.key !== 'Tab' || !modal || modal.style.display === 'none') return;
    const focusable = Array.from(
      modal.querySelectorAll('a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])')
    ).filter(el => !el.closest('[aria-hidden="true"]'));
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
  });

</script>

<!-- ─────────────────────────────────────────────────────────────
     MODAL STYLES  (scoped here — no global.css changes needed)
───────────────────────────────────────────────────────────── -->
<style>
  /* Mobile: slide up from bottom */
  @media (max-width: 639px) {
    #modal-panel {
      border-radius: 1.5rem 1.5rem 0 0 !important;
      max-height: 92dvh !important;
    }
  }

  /* Desktop: centered card */
  @media (min-width: 640px) {
    #modal-panel {
      border-radius: 1.5rem !important;
    }
  }

  /* Gallery main image transition */
  #modal-main-image {
    transition: opacity 0.12s ease, transform 0.12s ease;
  }

  /* Thumb hover */
  .gallery-thumb:hover {
    opacity: 1 !important;
    transform: scale(1.1) !important;
  }

  /* Close button hover */
  #modal-close:hover {
    background: rgba(47,62,70,0.14) !important;
  }

  /* Smooth scroll inside panel */
  #modal-panel > div {
    scroll-behavior: smooth;
  }

  /* Ticket stub still applies inside modal cards */
  .ticket-stub::before {
    content: '';
    position: absolute;
    bottom: 4.5rem;
    left: 0; right: 0;
    height: 1px;
    background: repeating-linear-gradient(
      90deg,
      rgba(0,95,115,0.22) 0, rgba(0,95,115,0.22) 5px,
      transparent 5px, transparent 11px
    );
  }
</style>
