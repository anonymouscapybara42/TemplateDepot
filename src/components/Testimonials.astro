---
// Testimonials.astro

const testimonials = [
  {
    name: 'Maricel Santos',
    role: 'Virtual Assistant, Cebu City',
    text: 'The VA Client Dashboard template saved me so much setup time. My clients love how organized everything looks now. Worth every peso!',
    rating: 5,
    avatar: 'MS',
    color: 'from-indigo-500 to-violet-600',
  },
  {
    name: 'Jay Reyes',
    role: 'Real Estate Agent, Manila',
    text: 'The Real Estate Brochure Set is exactly what I needed. Sent my first property brochure within 20 minutes of downloading. Super professional!',
    rating: 5,
    avatar: 'JR',
    color: 'from-cyan-500 to-teal-600',
  },
  {
    name: 'Andrea Lim',
    role: 'Financial Advisor, Quezon City',
    text: 'My client presentations look 10x better since I started using the Financial Advisor Deck template. The layout is clean and impresses clients every time.',
    rating: 5,
    avatar: 'AL',
    color: 'from-pink-500 to-rose-600',
  },
  {
    name: 'Carlo Mendoza',
    role: 'Freelance Designer, Davao',
    text: 'Template Depot has great designs and the delivery was fast. Got my templates in less than an hour after sending my GCash payment. Highly recommend!',
    rating: 5,
    avatar: 'CM',
    color: 'from-amber-500 to-orange-600',
  },
  {
    name: 'Trisha Villanueva',
    role: 'Small Business Owner, Iloilo',
    text: 'The Small Business Starter Pack was the best investment I made this year. Logo guide, invoices, social media — everything in one bundle. Amazing value!',
    rating: 5,
    avatar: 'TV',
    color: 'from-violet-500 to-purple-600',
  },
  {
    name: 'Mark Gutierrez',
    role: 'Content Creator, Bacolod',
    text: 'The Social Media Content Kit has 60+ templates and I\'ve barely scratched the surface. My Instagram engagement went up immediately. 5 stars!',
    rating: 5,
    avatar: 'MG',
    color: 'from-fuchsia-500 to-pink-600',
  },
];
---

<section id="testimonials" class="py-24 lg:py-32 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-navy-900 via-navy-800/20 to-navy-900 pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/4 w-[400px] h-[400px] bg-violet-600/6 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="section-label">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 12 12">
          <path d="M6 1l1.5 3H11L8.5 6l1 3.5L6 8l-3.5 1.5 1-3.5L1 4h3.5L6 1z"/>
        </svg>
        Testimonials
      </span>
      <h2 class="section-title text-3xl sm:text-4xl lg:text-5xl mt-3 mb-4">
        Trusted by professionals<br />
        <span class="text-gradient">across the Philippines</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Don't just take our word for it — here's what our customers say.
      </p>
    </div>

    <!-- Testimonials slider -->
    <div class="relative overflow-hidden reveal">
      <div id="testimonials-track" class="flex gap-5 transition-transform duration-500 ease-out">
        {testimonials.map((t) => (
          <div class="testimonial-card flex-none w-[320px] sm:w-[380px] glass rounded-2xl border border-white/8 p-6 card-hover">
            <!-- Stars -->
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Text -->
            <p class="text-slate-300 text-sm leading-relaxed mb-6">
              "{t.text}"
            </p>

            <!-- Author -->
            <div class="flex items-center gap-3">
              <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${t.color} flex items-center justify-center flex-shrink-0`}>
                <span class="text-xs font-display font-bold text-white">{t.avatar}</span>
              </div>
              <div>
                <p class="font-display font-semibold text-white text-sm">{t.name}</p>
                <p class="text-xs text-slate-500">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Fade edges -->
      <div class="absolute top-0 left-0 bottom-0 w-16 bg-gradient-to-r from-navy-900 to-transparent pointer-events-none z-10"></div>
      <div class="absolute top-0 right-0 bottom-0 w-16 bg-gradient-to-l from-navy-900 to-transparent pointer-events-none z-10"></div>
    </div>

    <!-- Controls -->
    <div class="flex items-center justify-center gap-4 mt-8 reveal">
      <button id="prev-btn" class="w-10 h-10 rounded-full glass border border-white/15 flex items-center justify-center text-slate-400 hover:text-white hover:border-white/30 transition-all">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <div id="dots" class="flex gap-2">
        {testimonials.map((_, i) => (
          <button class={`dot w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-indigo-400 w-6' : 'bg-white/20'}`} data-index={i}></button>
        ))}
      </div>
      <button id="next-btn" class="w-10 h-10 rounded-full glass border border-white/15 flex items-center justify-center text-slate-400 hover:text-white hover:border-white/30 transition-all">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

  </div>
</section>

<script>
  const track = document.getElementById('testimonials-track');
  const dots = document.querySelectorAll('.dot');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  let current = 0;
  const cards = track?.querySelectorAll('.testimonial-card');
  const total = cards?.length ?? 0;

  function getCardWidth() {
    if (!cards || cards.length === 0) return 320;
    const card = cards[0] as HTMLElement;
    return card.offsetWidth + 20; // width + gap
  }

  function goTo(index: number) {
    if (!track) return;
    current = Math.max(0, Math.min(index, total - 1));
    track.style.transform = `translateX(-${current * getCardWidth()}px)`;

    dots.forEach((dot, i) => {
      if (i === current) {
        dot.classList.add('bg-indigo-400', 'w-6');
        dot.classList.remove('bg-white/20');
      } else {
        dot.classList.remove('bg-indigo-400', 'w-6');
        dot.classList.add('bg-white/20');
      }
    });
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

  // Auto-play
  setInterval(() => goTo(current + 1 < total ? current + 1 : 0), 5000);
</script>
