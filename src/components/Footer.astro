---
// Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="relative" style="background:#2F3E46;">
  <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg, transparent, rgba(10,147,150,0.5), transparent);"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="#home" class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center shadow-md" style="background:linear-gradient(135deg,#005F73,#0A9396);">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="2" y="2" width="6" height="6" rx="1.5" fill="white" opacity="0.9"/>
              <rect x="10" y="2" width="6" height="6" rx="1.5" fill="white" opacity="0.7"/>
              <rect x="2" y="10" width="6" height="6" rx="1.5" fill="white" opacity="0.7"/>
              <rect x="10" y="10" width="6" height="6" rx="1.5" fill="white" opacity="0.5"/>
            </svg>
          </div>
          <span class="font-display font-bold text-lg tracking-tight text-white">
            Template<span style="background:linear-gradient(135deg,#0A9396,#22D3EE); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Depot</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed max-w-xs mb-6" style="color:rgba(232,245,233,0.65);">
          Premium ready-made digital templates for professionals, freelancers, and small businesses. Save time. Look professional.
        </p>
        <div class="flex items-center gap-3">
          <a href="https://facebook.com/templatedepot" target="_blank" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all" style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12);" aria-label="Facebook">
            <svg class="w-4 h-4" fill="#E8F5E9" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://m.me/templatedepot" target="_blank" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all" style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12);" aria-label="Messenger">
            <svg class="w-4 h-4" fill="#E8F5E9" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.917 1.455 5.52 3.733 7.232V22l3.405-1.88c.909.253 1.872.39 2.862.39 5.523 0 10-4.144 10-9.267C22 6.145 17.523 2 12 2zm.99 12.476l-2.548-2.717-4.97 2.717 5.467-5.8 2.608 2.717 4.91-2.717-5.467 5.8z"/>
            </svg>
          </a>
          <a href="mailto:hello@templatedepot.com" class="w-9 h-9 rounded-lg flex items-center justify-center transition-all" style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12);" aria-label="Email">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="#E8F5E9" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-display font-semibold text-sm mb-4 text-white">Quick Links</h4>
        <ul class="space-y-2.5">
          {[
            { label: 'Home', href: '#home' },
            { label: 'Templates', href: '#templates' },
            { label: 'How to Purchase', href: '#how-to-purchase' },
            { label: 'Payment Info', href: '#payment' },
            { label: 'Testimonials', href: '#testimonials' },
            { label: 'FAQ', href: '#faq' },
            { label: 'Submit Payment', href: '/submit-payment' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-sm transition-colors" style="color:rgba(232,245,233,0.65);"
                onmouseover="this.style.color='#E8F5E9'" onmouseout="this.style.color='rgba(232,245,233,0.65)'"
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display font-semibold text-sm mb-4 text-white">Get In Touch</h4>
        <ul class="space-y-3">
          <li>
            <p class="text-xs uppercase tracking-wider mb-0.5" style="color:rgba(232,245,233,0.40);">Email</p>
            <a href="mailto:hello@templatedepot.com" class="text-sm" style="color:rgba(232,245,233,0.65);">hello@templatedepot.com</a>
          </li>
          <li>
            <p class="text-xs uppercase tracking-wider mb-0.5" style="color:rgba(232,245,233,0.40);">Messenger</p>
            <a href="https://m.me/templatedepot" target="_blank" class="text-sm" style="color:rgba(232,245,233,0.65);">m.me/templatedepot</a>
          </li>
          <li>
            <p class="text-xs uppercase tracking-wider mb-0.5" style="color:rgba(232,245,233,0.40);">Business Hours</p>
            <p class="text-sm" style="color:rgba(232,245,233,0.65);">Mon–Sat, 9AM–6PM PHT</p>
          </li>
        </ul>
      </div>
    </div>

    <div class="w-full h-px mb-6" style="background:rgba(255,255,255,0.08);"></div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs" style="color:rgba(232,245,233,0.40);">&copy; {currentYear} Template Depot. All rights reserved.</p>
      <span class="text-xs" style="color:rgba(232,245,233,0.40);">Template Depot</span>
    </div>
  </div>
</footer>