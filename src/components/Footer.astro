---
// Footer.astro
const year = new Date().getFullYear();

const quickLinks = [
  { label: 'Home',            href: '/#home' },
  { label: 'Templates',       href: '/#templates' },
  { label: 'How to Purchase', href: '/#how-to-purchase' },
  { label: 'Payment Info',    href: '/#payment' },
  { label: 'Testimonials',    href: '/#testimonials' },
  { label: 'FAQ',             href: '/#faq' },
  { label: 'Submit Payment',  href: '/submit-payment' },
];
---

<footer role="contentinfo" style="background:var(--charcoal); color:rgba(232,245,233,0.70);">
  <!-- Top gradient line -->
  <div
    class="h-px w-full"
    style="background:linear-gradient(90deg, transparent, rgba(10,147,150,0.55), transparent);"
    aria-hidden="true"
  ></div>

  <div class="container-xl pt-14 pb-8">

    <!-- Main grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <a
          href="/"
          class="inline-flex items-center gap-2.5 mb-4"
          aria-label="Template Depot — home"
        >
          <img
            src="/logo.png"
            alt=""
            width="32"
            height="32"
            class="w-8 h-8 rounded-xl shrink-0"
            aria-hidden="true"
          />
          <span class="font-display font-bold text-white" style="font-size:1.0625rem; letter-spacing:-0.02em;">
            Template<span style="background:linear-gradient(135deg,#0A9396,#22D3EE);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Depot</span>
          </span>
        </a>

        <p class="text-sm leading-relaxed max-w-xs mb-6">
          Premium ready-made digital templates for Filipino professionals, freelancers, and small businesses.
          Save time. Look professional.
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-2.5" role="list" aria-label="Social media links">
          {[
            {
              href: 'https://www.facebook.com/profile.php?id=61590735058749',
              label: 'Facebook Page',
              icon: `<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>`,
              fill: true,
            },
            {
              href: 'https://m.me/61590735058749',
              label: 'Messenger',
              icon: `<path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.917 1.455 5.52 3.733 7.232V22l3.405-1.88c.909.253 1.872.39 2.862.39 5.523 0 10-4.144 10-9.267C22 6.145 17.523 2 12 2zm.99 12.476l-2.548-2.717-4.97 2.717 5.467-5.8 2.608 2.717 4.91-2.717-5.467 5.8z"/>`,
              fill: true,
            },
            {
              href: 'mailto:hello@templatedepot.com',
              label: 'Email',
              icon: `<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
              fill: false,
            },
          ].map(s => (
            <div role="listitem">
              <a
                href={s.href}
                target={s.href.startsWith('mailto') ? undefined : '_blank'}
                rel={s.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
                aria-label={s.label}
                class="w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-200 hover:opacity-90"
                style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12);"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill={s.fill ? 'rgba(232,245,233,0.85)' : 'none'} stroke={s.fill ? 'none' : 'rgba(232,245,233,0.85)'} stroke-width={s.fill ? undefined : '1.75'} aria-hidden="true">
                  <Fragment set:html={s.icon} />
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- Quick links -->
      <nav aria-label="Footer quick links">
        <h3 class="font-display font-semibold text-sm text-white mb-4">Quick Links</h3>
        <ul class="space-y-2.5">
          {quickLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-150 hover:text-white"
                style="color:rgba(232,245,233,0.65);"
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact info -->
      <div>
        <h3 class="font-display font-semibold text-sm text-white mb-4">Get In Touch</h3>
        <ul class="space-y-4">
          {[
            { label: 'Email',         val: 'hello@templatedepot.com', href: 'mailto:hello@templatedepot.com' },
            { label: 'Messenger',     val: 'Template Depot',      href: 'hhttps://m.me/61590735058749' },
            { label: 'Business Hours', val: 'Mon–Sat, 9PM–5AM (PHT)',   href: null },
          ].map(item => (
            <li>
              <p class="font-display" style="font-size:0.65rem; letter-spacing:0.08em; text-transform:uppercase; color:rgba(232,245,233,0.35); margin-bottom:0.2rem;">{item.label}</p>
              {item.href
                ? <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="text-sm transition-colors duration-150 hover:text-white" style="color:rgba(232,245,233,0.65);">{item.val}</a>
                : <p class="text-sm" style="color:rgba(232,245,233,0.65);">{item.val}</p>
              }
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-6"
      style="border-top:1px solid rgba(255,255,255,0.08);"
    >
      <p class="text-xs text-center sm:text-left" style="color:rgba(232,245,233,0.35);">
        &copy; {year} Template Depot. All rights reserved.
      </p>
      <p class="text-xs" style="color:rgba(232,245,233,0.35);">
       
      </p>
    </div>

  </div>
</footer>
