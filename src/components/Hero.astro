\---
// Hero.astro
---
<!-- Headline -->
<h1 class="hero-title animate-fade-up delay-200">

<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- Background elements -->
  <div class="absolute inset-0 bg-grid-pattern opacity-30 pointer-events-none"></div>
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-600/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/2 right-0 w-[400px] h-[400px] bg-cyan-500/8 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-indigo-500/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass border border-indigo-500/30 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse-slow"></span>
          <span class="text-xs font-display font-semibold text-#323E45 tracking-wider uppercase">New Templates Added Weekly</span>
        </div>

        <!-- Headline -->
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl xl:text-7xl text-'#323E45' leading-[1.05] tracking-tight mb-6">
          Premium Digital<br />
          <span class="text-gradient">Templates</span><br />
          Ready for Use
        </h1>

        <!-- Subheadline -->
        <p class="text-slate-400 text-lg sm:text-xl leading-relaxed max-w-xl mx-auto lg:mx-0 mb-8">
          Professional templates designed to save you time and elevate your projects. 
          From business docs to social media — we have what you need.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-3 mb-12">
          <a href="#templates" class="btn-primary text-base px-8 py-3.5 w-full sm:w-auto justify-center">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 5h12M3 9h12M3 13h8"/>
            </svg>
            Browse Templates
          </a>
          <a href="#contact" class="btn-secondary text-base px-8 py-3.5 w-full sm:w-auto justify-center">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 8.5A5.5 5.5 0 0 1 8.5 3h1A5.5 5.5 0 0 1 15 8.5v1a5.5 5.5 0 0 1-5.5 5.5"/>
              <path d="M3 14.5l3-3"/>
            </svg>
            Contact Us
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-2">
              {['bg-indigo-500', 'bg-cyan-500', 'bg-violet-500', 'bg-pink-500'].map(c => (
                <div class={`w-7 h-7 rounded-full ${c} border-2 border-navy-900 flex items-center justify-center text-white text-xs font-bold`}>
                  ✓
                </div>
              ))}
            </div>
            <span class="text-sm text-slate-400">500+ happy customers</span>
          </div>
          <div class="flex items-center gap-1.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
            <span class="text-sm text-slate-400 ml-1">4.9/5 rating</span>
          </div>
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="relative flex items-center justify-center animate-float">
        <!-- Main card stack -->
        <div class="relative w-full max-w-md">
          <!-- Back cards -->
          <div class="absolute top-4 left-4 right-4 h-72 glass rounded-2xl border border-indigo-500/20 rotate-3 opacity-40"></div>
          <div class="absolute top-2 left-2 right-2 h-72 glass rounded-2xl border border-cyan-400/20 -rotate-2 opacity-60"></div>

          <!-- Main mockup card -->
          <div class="relative glass rounded-2xl border border-white/15 overflow-hidden shadow-2xl shadow-indigo-500/20">
            <!-- Card header -->
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/8">
              <div class="flex items-center gap-2">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/70"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/70"></div>
              </div>
              <div class="flex items-center gap-1.5 px-3 py-1 rounded-md bg-white/5 border border-white/8">
                <div class="w-1.5 h-1.5 rounded-full bg-cyan-400"></div>
                <span class="text-xs text-slate-400 font-display">template-depot.pages.dev</span>
              </div>
            </div>

            <!-- Mockup content -->
            <div class="p-5 space-y-4">
              <!-- Template preview rows -->
              {[
                { name: 'Business Proposal Kit', cat: 'Business', price: '₱299', color: 'from-indigo-500/20 to-cyan-500/20', tag: 'Popular' },
                { name: 'VA Client Dashboard', cat: 'Productivity', price: '₱249', color: 'from-violet-500/20 to-pink-500/20', tag: 'New' },
                { name: 'Real Estate Brochure', cat: 'Marketing', price: '₱279', color: 'from-cyan-500/20 to-teal-500/20', tag: '' },
              ].map(t => (
                <div class="flex items-center gap-3 p-3 rounded-xl bg-white/3 hover:bg-white/6 border border-white/5 transition-all cursor-pointer group">
                  <div class={`w-12 h-12 rounded-lg bg-gradient-to-br ${t.color} flex items-center justify-center flex-shrink-0 border border-white/10`}>
                    <svg class="w-5 h-5 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <p class="text-sm font-display font-semibold text-white truncate">{t.name}</p>
                      {t.tag && (
                        <span class="text-xs px-1.5 py-0.5 rounded-md bg-indigo-500/20 text-indigo-400 font-medium flex-shrink-0">{t.tag}</span>
                      )}
                    </div>
                    <p class="text-xs text-slate-500">{t.cat}</p>
                  </div>
                  <span class="text-sm font-display font-bold text-cyan-400 flex-shrink-0">{t.price}</span>
                </div>
              ))}

              <!-- Bottom CTA in mockup -->
              <div class="flex items-center justify-between pt-1">
                <span class="text-xs text-slate-500">8 templates available</span>
                <button class="text-xs font-display font-semibold text-indigo-400 hover:text-indigo-300 transition-colors">View all →</button>
              </div>
            </div>
          </div>

          <!-- Floating badges -->
          <div class="absolute -top-3 -right-3 glass border border-cyan-400/30 rounded-xl px-3 py-2 shadow-lg">
            <div class="flex items-center gap-2">
              <span class="text-lg">⚡</span>
              <div>
                <p class="text-xs font-display font-bold text-white">Instant</p>
                <p class="text-xs text-slate-400">Delivery</p>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-3 -left-3 glass border border-indigo-500/30 rounded-xl px-3 py-2 shadow-lg">
            <div class="flex items-center gap-2">
              <span class="text-lg">🎨</span>
              <div>
                <p class="text-xs font-display font-bold text-white">Pro Design</p>
                <p class="text-xs text-slate-400">Ready to use</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce opacity-50">
    <span class="text-xs font-display text-slate-500 tracking-widest uppercase">Scroll</span>
    <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
