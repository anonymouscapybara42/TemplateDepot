---
// Hero.astro
---

<section id="home" class="relative overflow-hidden" style="background: linear-gradient(160deg, #EEF7F8 0%, #ffffff 55%, #EAF5EB 100%);">
  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 bg-grid-pattern pointer-events-none" style="opacity:0.5;"></div>
  <!-- Ambient blobs -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[640px] h-[480px] rounded-full pointer-events-none blur-3xl" style="background: radial-gradient(ellipse, rgba(0,95,115,0.07) 0%, transparent 70%);"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full pointer-events-none blur-3xl" style="background: rgba(10,147,150,0.06);"></div>

  <div class="container-xl relative py-20 lg:py-28 xl:py-32">
    <div class="grid lg:grid-cols-2 gap-12 xl:gap-20 items-center">

      <!-- ── Left: Copy ─────────────────────────────────────────── -->
      <div class="text-center lg:text-left">

        <!-- Eyebrow badge -->
        <div
          class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full mb-6 sm:mb-8"
          style="background: rgba(0,95,115,0.08); border: 1px solid rgba(0,95,115,0.18);"
        >
          <span class="w-1.5 h-1.5 rounded-full animate-pulse-soft shrink-0" style="background: var(--teal-mid);"></span>
          <span class="eyebrow" style="font-size: 0.7rem;">New Templates Added Weekly</span>
        </div>

        <!-- Heading -->
        <h1 class="font-display font-bold mb-5 sm:mb-6" style="color: var(--charcoal);">
          Premium Digital<br />
          <span class="text-teal-gradient">Templates</span><br />
          Ready for Use
        </h1>

        <!-- Sub-copy -->
        <p class="text-lg sm:text-xl leading-relaxed mb-8 sm:mb-10 max-w-lg mx-auto lg:mx-0" style="color: var(--text-secondary);">
          Professional templates designed to save you time and elevate your projects.
          From business docs to social media — we've got you covered.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start mb-10 sm:mb-12">
          <a href="#templates" class="btn btn-primary btn-lg w-full sm:w-auto">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" aria-hidden="true">
              <path d="M2 4h12M2 8h12M2 12h7"/>
            </svg>
            Browse Templates
          </a>
          <a
            href="https://m.me/61590735058749"
            target="_blank" rel="noopener noreferrer"
            class="btn btn-messenger btn-lg w-full sm:w-auto"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.917 1.455 5.52 3.733 7.232V22l3.405-1.88c.909.253 1.872.39 2.862.39 5.523 0 10-4.144 10-9.267C22 6.145 17.523 2 12 2zm.99 12.476l-2.548-2.717-4.97 2.717 5.467-5.8 2.608 2.717 4.91-2.717-5.467 5.8z"/>
            </svg>
            Chat on Messenger
          </a>
        </div>

        <!-- Social proof -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-5 sm:gap-6">
          <!-- Avatar stack -->
          <div class="flex items-center gap-2.5">
            <div class="flex -space-x-2" aria-hidden="true">
              {['#005F73','#0A9396','#2F3E46','#EE9B00'].map((c, i) => (
                <div
                  class="w-7 h-7 rounded-full flex items-center justify-center text-white text-xs font-bold border-2"
                  style={`background:${c}; border-color: #EEF7F8; z-index:${4-i};`}
                >✓</div>
              ))}
            </div>
            <span class="text-sm font-medium" style="color: var(--text-secondary);">
              <span class="tabular-nums" data-counter data-counter-target="500">0+</span>
              happy customers
            </span>
          </div>

          <!-- Star rating -->
          <div class="flex items-center gap-1.5">
            <div class="flex" aria-label="4.9 out of 5 stars">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4" fill="#EE9B00" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <span class="text-sm font-medium" style="color: var(--text-secondary);">4.9 / 5</span>
          </div>
        </div>
      </div>

      <!-- ── Right: Mockup ──────────────────────────────────────── -->
      <div class="relative hidden sm:flex items-center justify-center animate-float">
        <div class="relative w-full max-w-[420px]">

          <!-- Shadow stack cards -->
          <div
            class="absolute inset-4 rounded-2xl rotate-3 opacity-30"
            style="background: var(--mint); border: 1px solid var(--border-mid);"
            aria-hidden="true"
          ></div>
          <div
            class="absolute inset-2 rounded-2xl -rotate-2 opacity-55"
            style="background: var(--surface-tint); border: 1px solid var(--border);"
            aria-hidden="true"
          ></div>

          <!-- Main browser card -->
          <div
            class="relative rounded-2xl overflow-hidden"
            style="background: var(--surface); border: 1px solid var(--border); box-shadow: 0 24px 64px rgba(0,95,115,0.15);"
            aria-label="Preview of Template Depot interface"
          >
            <!-- Browser chrome bar -->
            <div class="flex items-center justify-between px-4 py-3" style="border-bottom: 1px solid var(--border); background: var(--surface-tint);">
              <div class="flex items-center gap-1.5" aria-hidden="true">
                <div class="w-2.5 h-2.5 rounded-full" style="background:#F87171;"></div>
                <div class="w-2.5 h-2.5 rounded-full" style="background:#FBBF24;"></div>
                <div class="w-2.5 h-2.5 rounded-full" style="background:#34D399;"></div>
              </div>
              <div
                class="flex items-center gap-1.5 px-3 py-1 rounded-md text-xs font-display"
                style="background: var(--bg); border: 1px solid var(--border); color: var(--text-muted);"
              >
                <div class="w-1.5 h-1.5 rounded-full" style="background: var(--teal-mid);" aria-hidden="true"></div>
                templatedepot.com
              </div>
              <div class="w-16" aria-hidden="true"></div>
            </div>

            <!-- Template rows -->
            <div class="p-4 space-y-2.5">
              {[
                { name: 'Business Proposal Kit', cat: 'Business',    price: '₱299', tag: 'Popular', bg: 'rgba(0,95,115,0.08)' },
                { name: 'VA Client Dashboard',   cat: 'Productivity', price: '₱249', tag: 'New',     bg: 'rgba(10,147,150,0.08)' },
                { name: 'Real Estate Brochure',  cat: 'Marketing',   price: '₱279', tag: '',        bg: 'rgba(47,62,70,0.06)' },
              ].map(t => (
                <div
                  class="flex items-center gap-3 p-3 rounded-xl transition-colors duration-150"
                  style="background: var(--bg); border: 1px solid var(--border);"
                >
                  <div
                    class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
                    style={`background:${t.bg}; border:1px solid rgba(0,95,115,0.12);`}
                    aria-hidden="true"
                  >
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" style="color: var(--teal-primary);">
                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-1.5 min-w-0">
                      <p class="text-sm font-display font-semibold truncate" style="color:var(--charcoal);">{t.name}</p>
                      {t.tag && (
                        <span class="badge badge-teal shrink-0">{t.tag}</span>
                      )}
                    </div>
                    <p class="text-xs mt-0.5" style="color:var(--text-faint);">{t.cat}</p>
                  </div>
                  <span class="text-sm font-display font-bold shrink-0" style="color:var(--teal-mid);">{t.price}</span>
                </div>
              ))}

              <div class="flex items-center justify-between pt-1">
                <span class="text-xs" style="color:var(--text-faint);">8 templates available</span>
                <a href="#templates" class="text-xs font-display font-semibold" style="color:var(--teal-primary);">View all →</a>
              </div>
            </div>
          </div>

          <!-- Floating chips -->
          <div
            class="absolute -top-3 -right-4 px-3 py-2 rounded-xl shadow-md flex items-center gap-2"
            style="background:var(--surface); border:1px solid var(--border);"
            aria-hidden="true"
          >
            <span class="text-lg" role="img" aria-label="lightning">⚡</span>
            <div>
              <p class="text-xs font-display font-bold" style="color:var(--charcoal); line-height:1.2;">Instant</p>
              <p class="text-xs" style="color:var(--text-faint); line-height:1.2;">Delivery</p>
            </div>
          </div>

          <div
            class="absolute -bottom-3 -left-4 px-3 py-2 rounded-xl shadow-md flex items-center gap-2"
            style="background:var(--surface); border:1px solid var(--border);"
            aria-hidden="true"
          >
            <span class="text-lg" role="img" aria-label="art">🎨</span>
            <div>
              <p class="text-xs font-display font-bold" style="color:var(--charcoal); line-height:1.2;">Pro Design</p>
              <p class="text-xs" style="color:var(--text-faint); line-height:1.2;">Ready to use</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator (hidden on mobile to save space) -->
  <div
    class="hidden sm:flex absolute bottom-6 left-1/2 -translate-x-1/2 flex-col items-center gap-1.5 animate-bounce"
    style="opacity:0.4;"
    aria-hidden="true"
  >
    <span class="eyebrow" style="font-size:0.6rem; color:var(--teal-primary);">Scroll</span>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="color:var(--teal-primary);">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<script>
  const animateCounter = () => {
    const counter = document.querySelector('[data-counter]');

    if (!counter) return;

    const target = Number(counter.getAttribute('data-counter-target') || '0');
    const duration = 1600;
    const startTime = performance.now();

    const updateValue = (currentTime: number) => {
      const progress = Math.min((currentTime - startTime) / duration, 1);
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      const currentValue = Math.round(target * easedProgress);

      counter.textContent = `${currentValue}+`;

      if (progress < 1) {
        requestAnimationFrame(updateValue);
      } else {
        counter.textContent = `${target}+`;
      }
    };

    counter.textContent = '0+';
    requestAnimationFrame(updateValue);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', animateCounter, { once: true });
  } else {
    animateCounter();
  }
</script>
